# ──────────────────────────────────────────────────────────────────────────────
# NewsCollectorAgent — environment configuration
# Copy to .env and fill in real values before deploying.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection (remote VM) ─────────────────────────────────────────
# Option A — full DSN (takes priority if set)
# POSTGRES_DSN=postgresql://newsuser:secret@192.168.1.10:5432/newsdb

# Option B — individual fields
POSTGRES_HOST=192.168.1.10
POSTGRES_PORT=5432
POSTGRES_DB=newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=changeme
POSTGRES_SSLMODE=prefer          # prefer | require | disable

# ── Collector behaviour ───────────────────────────────────────────────────────
# How often (minutes) to poll all RSS feeds
COLLECT_INTERVAL_MINUTES=15

# Politeness delay (seconds) between individual feed HTTP requests
REQUEST_DELAY_SECONDS=1.5

# Retention window for old articles (days)
RETENTION_DAYS=365

# Set to "true" to do one collection cycle and exit (useful for cron / testing)
RUN_ONCE=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
